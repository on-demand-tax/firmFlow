# MongoDB Atlas connection string
MONGODB_URI=

# NextAuth session encryption
NEXTAUTH_SECRET=

# Public app URL (e.g. http://localhost:3000 in development)
NEXTAUTH_URL=

# Google OAuth (NextAuth sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Allowed Workspace domain without @ (e.g. yourfirm.com)
ALLOWED_EMAIL_DOMAIN=

# First admin account email (required before other users can sign up)
INITIAL_ADMIN_EMAIL=

# Google Drive service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Root Drive folder for FirmFlow_Data
GOOGLE_DRIVE_MASTER_FOLDER_ID=
